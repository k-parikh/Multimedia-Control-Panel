void handleRoot(){server.send(200,"text/html",htmlPageRoot());}
void handleReset(){
  server.send(200,"text/html","<html><body><h3>Resetting Wi-Fi…</h3><p>Device will reboot.</p></body></html>");
  delay(500);WiFi.disconnect(true,true);delay(200);ESP.restart();
}

/*** ---------- SETUP ---------- ***/
void setup(){
  pinMode(LED_BT,OUTPUT);
  pinMode(LED_MIC,OUTPUT);
  pinMode(LED_CAM,OUTPUT);
  digitalWrite(LED_BT,LOW);
  digitalWrite(LED_MIC,LOW);
  digitalWrite(LED_CAM,LOW);

  pinMode(BTN_MODE,INPUT_PULLUP);
  pinMode(BTN_PLUS,INPUT_PULLUP);
  pinMode(BTN_MINUS,INPUT_PULLUP);
  pinMode(BTN_YT,INPUT_PULLUP);
  pinMode(BTN_MIC,INPUT_PULLUP);
  pinMode(BTN_CAM,INPUT_PULLUP);

  Wire.begin(OLED_SDA,OLED_SCL);
  display.begin(SSD1306_SWITCHCAPVCC,OLED_ADDR);
  display.setRotation(2);display.clearDisplay();display.display();

  WiFiManager wm;
  String apName="ESP32-Setup-"+String((uint32_t)ESP.getEfuseMac(),HEX).substring(4);
  showSetupScreen(apName);
  if(!wm.autoConnect(apName.c_str(),"esp32setup")){
    drawCentered("Setup failed!",28,1);display.display();delay(2000);ESP.restart();
  }

  configTzTime(TZ_INFO,"pool.ntp.org","time.nist.gov");

  String mdnsName="clockdeck";String shownAddr=WiFi.localIP().toString();
  if(MDNS.begin(mdnsName.c_str())){MDNS.addService("http","tcp",80);shownAddr="http://"+mdnsName+".local";}
  showConnectedScreen(shownAddr);

  server.on("/",handleRoot);
  server.on("/reset",handleReset);
  server.begin();

  BLEDevice::init("ESP32 Clock Deck");
  BLEDevice::setPower(ESP_PWR_LVL_P7);
  bleKeyboard.begin();

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);
  setMode(MODE_CLOCK);
}

/*** ---------- LOOP ---------- ***/
void loop(){
  server.handleClient();
  digitalWrite(LED_BT,bleKeyboard.isConnected()?HIGH:LOW);

  if(timerDone){
    unsigned long e=millis()-flashStart;
    if(e<5000)digitalWrite(LED_BT,(e/200)%2);
    else{timerDone=false;digitalWrite(LED_BT,bleKeyboard.isConnected());}
  }

  if(millis()<vcOverlayUntil){
    // Overlay active; skip normal rendering
  } else {
    switch(currentMode){
      case MODE_CLOCK: renderClock(); break;
      case MODE_TIMER: renderTimer(); break;
      case MODE_STOPWATCH: renderStopwatch(); break;
    }
  }

  // --- Mode switch ---
  static bool lastMode=HIGH;
  bool modeNow=digitalRead(BTN_MODE);
  if(lastMode==HIGH && modeNow==LOW){cycleMode();delay(200);}
  lastMode=modeNow;

  // --- Timer controls ---
  if(currentMode==MODE_TIMER){
    bool plus=digitalRead(BTN_PLUS)==LOW;
    bool minus=digitalRead(BTN_MINUS)==LOW;
    if(!timerRunning){
      if(plus&&!minus){timerSeconds=min(timerSeconds+60,359999);delay(160);}
      if(minus&&!plus){timerSeconds=max(timerSeconds-60,0);delay(160);}
      if(plus&&minus){timerRunning=true;lastSecondTick=millis();delay(300);}
    }else if(plus&&minus){timerRunning=false;delay(300);}
  }

  // --- Stopwatch controls ---
  if(currentMode==MODE_STOPWATCH){
    bool plus=digitalRead(BTN_PLUS)==LOW;
    bool minus=digitalRead(BTN_MINUS)==LOW;
    if(plus&&!swRunning){swRunning=true;swStartMillis=millis()-swElapsedMs;delay(160);}
    if(minus&&swRunning){swElapsedMs=millis()-swStartMillis;swRunning=false;delay(160);}
  }

  // --- YouTube / VC Mode Button ---
  handleYouTubeButton();

  // --- Conference Buttons (Mic/Camera) ---
  handleConferenceButtons();

  // --- Background Volume ---
  volumeBackgroundUpdate();

  delay(50);
}

